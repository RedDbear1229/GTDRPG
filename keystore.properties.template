# keystore.properties — 이 파일을 복사해 keystore.properties 로 이름 변경 후 실제 값 입력.
# keystore.properties 는 .gitignore 에 포함됨 — 절대 커밋하지 말 것.
#
# keystore 생성 명령:
#   keytool -genkeypair -v \
#     -keystore questlog-release.jks \
#     -alias questlog \
#     -keyalg RSA -keysize 2048 \
#     -validity 10000
#
# 생성된 .jks 파일은 프로젝트 루트 외부 안전한 위치에 보관할 것.

storeFile=/path/to/questlog-release.jks
storePassword=your_store_password
keyAlias=questlog
keyPassword=your_key_password
